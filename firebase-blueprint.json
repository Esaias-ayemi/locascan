{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile for students and lecturers",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "lecturer"] },
        "level": { "type": "string" },
        "department": { "type": "string" },
        "matric_number": { "type": "string" },
        "staff_id": { "type": "string" },
        "phone_number": { "type": "string" },
        "onboarding_completed": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "role"]
    },
    "Course": {
      "title": "Course",
      "description": "Course offered by a lecturer",
      "type": "object",
      "properties": {
        "course_code": { "type": "string" },
        "course_title": { "type": "string" },
        "lecturer_id": { "type": "string" },
        "level": { "type": "string" },
        "department": { "type": "string" },
        "required_attendance": { "type": "number" },
        "expected_classes": { "type": "number" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["course_code", "course_title", "lecturer_id", "level", "department"]
    },
    "CourseRegistration": {
      "title": "Course Registration",
      "description": "Student registration for a course",
      "type": "object",
      "properties": {
        "course_id": { "type": "string" },
        "student_id": { "type": "string" },
        "semester": { "type": "string" },
        "registered_at": { "type": "string", "format": "date-time" }
      },
      "required": ["course_id", "student_id", "semester"]
    },
    "SemesterRegistration": {
      "title": "Semester Registration",
      "description": "Student registration for a semester",
      "type": "object",
      "properties": {
        "student_id": { "type": "string" },
        "semester": { "type": "string" },
        "registered_at": { "type": "string", "format": "date-time" }
      },
      "required": ["student_id", "semester"]
    },
    "Session": {
      "title": "Attendance Session",
      "description": "An active attendance tracking session",
      "type": "object",
      "properties": {
        "course_id": { "type": "string" },
        "lecturer_id": { "type": "string" },
        "qr_token": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "radius_meters": { "type": "number" },
        "expires_at": { "type": "string", "format": "date-time" },
        "is_active": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["course_id", "lecturer_id", "qr_token", "latitude", "longitude", "radius_meters", "expires_at", "is_active", "created_at"]
    },
    "Attendance": {
      "title": "Attendance Record",
      "description": "Record of a student's attendance for a session",
      "type": "object",
      "properties": {
        "session_id": { "type": "string" },
        "student_id": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "marked_at": { "type": "string", "format": "date-time" }
      },
      "required": ["session_id", "student_id", "latitude", "longitude", "marked_at"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "courses/{courseId}": {
      "schema": "Course",
      "description": "Courses"
    },
    "course_registrations/{registrationId}": {
      "schema": "CourseRegistration",
      "description": "Student course registrations"
    },
    "semester_registrations/{registrationId}": {
      "schema": "SemesterRegistration",
      "description": "Student semester registrations"
    },
    "sessions/{sessionId}": {
      "schema": "Session",
      "description": "Active attendance sessions"
    },
    "attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Attendance records"
    }
  }
}
